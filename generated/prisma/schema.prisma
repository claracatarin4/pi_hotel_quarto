// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model TipoQuarto {
  id        Int      @id @default(autoincrement()) @map("tipo_quarto_id")
  descricao String   @map("tipo_quarto_descricao") @db.VarChar(45)
  status    Int      @map("tipo_quarto_status")
  quartos   Quarto[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tipo_quarto")
}

model Quarto {
  id           Int        @id @default(autoincrement()) @map("quarto_id")
  numero       String     @map("quarto_numero") @db.VarChar(45)
  preco        Float      @map("quarto_preco") @db.Double
  status       Int        @map("quarto_status")
  tipoQuartoId Int        @map("tipo_quarto_id")
  tipoQuarto   TipoQuarto @relation(fields: [tipoQuartoId], references: [id])
  fotos        Foto[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("quarto")
}

model Foto {
  id        Int      @id @default(autoincrement()) @map("foto_id")
  nome      String   @map("foto_nome") @db.VarChar(45)
  bin       Bytes    @map("foto_bin") @db.LongBlob
  extensao  String   @map("foto_extensao") @db.VarChar(45)
  status    Int      @map("foto_status")
  quartoId  Int      @map("quarto_id")
  quarto    Quarto   @relation(fields: [quartoId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("foto")
}
